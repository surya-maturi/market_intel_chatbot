# Copy this file to backend/.env and fill in real values.
# Any key left blank makes that service run in demo mode: the app stays fully
# functional and visibly labels responses as sample data instead of crashing.

# Perplexity (intent classification + synthesis). Get a key at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Reddit (via asyncpraw). Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=market-intel-chatbot/2.0

# People Data Labs (company enrichment). Get a key at https://www.peopledatalabs.com/
PDL_API_KEY=

# Crunchbase is optional and disabled by default (no key required unless you enable it).
ENABLE_CRUNCHBASE=false
CRUNCHBASE_API_KEY=

# SQLite chat history path (relative to backend/ when running locally, or the
# container's volume mount when running via docker-compose).
DB_PATH=data/chat_history.db

# Origins allowed to call the API - must be valid JSON array syntax.
CORS_ORIGINS=["http://localhost:3000"]

REQUEST_TIMEOUT_SECONDS=15.0
MAX_RETRIES=2
LOG_LEVEL=INFO
LOG_JSON=false
