# Copy this file to frontend/.env.local for local development.
# In Vercel, set this as a project environment variable instead.

# Base URL of the deployed backend API (FastAPI). No trailing slash.
# Local dev default (used automatically if unset): http://localhost:8000
#
# If frontend and backend are deployed as one Vercel project via the root
# vercel.json (services + rewrites under a single domain), set this to the
# literal value "same-origin" instead - that makes API calls same-origin
# relative paths (e.g. "/api/chat/stream"), which the vercel.json rewrites
# route to the backend service. Leaving the var entirely unset falls back to
# http://localhost:8000, which is only correct for local dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
